{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "T-Drum",
  "version": "0.1.0",
  "identifier": "com.teddy.tdrum",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "T-Drum",
        "width": 1100,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#19181a"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
